{
  "name": "@fiap-13soat-techchallenge/auto-repair-shop-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@fiap-13soat-techchallenge/auto-repair-shop"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/auto-repair-shop-e2e/jest.config.js",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@fiap-13soat-techchallenge/auto-repair-shop:build",
          "@fiap-13soat-techchallenge/auto-repair-shop:serve"
        ]
      }
    }
  }
}
