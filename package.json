{
  "name": "@fiap-13soat-techchallenge/auto-repair-shop",
  "version": "1.3.1-SNAPSHOT",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "./auto-repair-shop/dist",
          "format": [
            "cjs"
          ],
          "bundle": false,
          "main": "./auto-repair-shop/src/main.ts",
          "tsConfig": "./auto-repair-shop/tsconfig.app.json",
          "assets": [
            "./auto-repair-shop/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "generateLockfile": true,
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/./auto-repair-shop/dist/package.json",
          "{workspaceRoot}/./auto-repair-shop/dist/yarn.lock"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/./auto-repair-shop/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@fiap-13soat-techchallenge/auto-repair-shop:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@fiap-13soat-techchallenge/auto-repair-shop:build:development"
          },
          "production": {
            "buildTarget": "@fiap-13soat-techchallenge/auto-repair-shop:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "docker:build": {
        "dependsOn": [
          "build",
          "prune"
        ]
      }
    }
  },
  "prisma": {
    "seed": "tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/autoload": "~6.0.3",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "~6.0.2",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "6.16.2",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "fastify": "~5.2.1",
    "fastify-plugin": "~5.0.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "nodemailer": "^7.0.9"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.2",
    "prisma": "^6.16.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6"
  }
}
